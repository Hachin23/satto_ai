{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./app/frontend/src/*"] 
    },
    "types": ["vite/client"]
  },
  "include": [
    "app/frontend/src/**/*.ts",
    "app/frontend/src/**/*.vue",
    "app/frontend/entrypoints/**/*.ts", // エントリーポイントも忘れずに
    "shims-vue.d.ts"
  ]
}